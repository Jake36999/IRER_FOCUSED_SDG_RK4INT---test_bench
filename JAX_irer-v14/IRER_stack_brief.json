  "simulation_workflow_and_data_lifecycle": {
    "overview": "Describes the end-to-end flow of simulation jobs, artifact generation, validation, and compliance enforcement across the IRER stack.",
    "workflow_steps": [
      "1. Orchestrator dispatches job manifest to worker via Redis queue.",
      "2. worker_v14_sdg.py receives manifest, validates parameters, initializes SimState, and runs simulation loop.",
      "3. During simulation, state matrices (rho, omega, A) are updated and checked for instability (NaN/Inf, divergence).",
      "4. Upon completion or early termination, worker uploads artifact (state, history, parameters) to MinIO storage.",
      "5. worker_bundle YAML (worker_bundle_20260218_032800.yaml) records manifest, compliance metadata, and provenance hash for the job.",
      "6. Validation pipeline (validation_pipeline.py) retrieves artifact, performs H-Norm, TDA, FFT, and entropy checks.",
      "7. analytics.py computes advanced metrics (Betti numbers, spectral properties, entropy) for artifact acceptance.",
      "8. check_invariance.py validates conservation laws and invariance properties for scientific rigor.",
      "9. Validation verdict (SUCCESS/REJECTED) and metrics are logged to Postgres and Redis; rejected artifacts are pushed to dead-letter queue.",
      "10. Compliance and provenance are enforced via manifest signing and governance hash checks throughout the workflow."
    ],
    "data_lifecycle": {
      "job_manifest": "Created by orchestrator, includes job_id, config, and parameters. Tracked in worker_bundle YAML.",
